{
  "sections": [
    {
      "title": "💳 Core Transaction",
      "fields": [
        {
          "name": "transaction_type",
          "type": "select",
          "label": "Transaction Type"
        },
        {
          "name": "amount_ngn",
          "type": "number",
          "label": "Amount (NGN)",
          "min": 1,
          "max": 1000000000,
          "default": 0
        },
        {
          "name": "merchant_category",
          "type": "select_mapped",
          "label": "Merchant Category",
          "options": {
            "🔄 Other Transaction":              "Other Transaction",
            "🚗 Bolt Ride":                      "Bolt Ride",
            "🛒 SPAR Purchase":                  "SPAR Purchase",
            "🏧 ATM Withdrawal":                 "ATM Withdrawal",
            "🎬 Filmhouse Cinemas Ticket":        "Filmhouse Cinemas Ticket",
            "🎲 Bet9ja Stake":                   "Bet9ja Stake",
            "🛍️ Shoprite Purchase":              "Shoprite Purchase",
            "💳 POS Withdrawal":                 "POS Withdrawal",
            "✈️ Arik Air Flight":                "Arik Air Flight",
            "🚌 ABC Transport Ticket":           "ABC Transport Ticket",
            "🎰 SportyBet Deposit":              "SportyBet Deposit",
            "🪣 Local Market Purchase":          "Local Market Purchase",
            "⛪ Church Offering":                "Church Offering",
            "⚡ Ikeja Electric Bill":            "Ikeja Electric Bill",
            "💸 Flutterwave Payment":            "Flutterwave Payment",
            "💰 Paystack Payment":               "Paystack Payment",
            "📺 DSTV Payment":                   "DSTV Payment",
            "📶 Data Subscription (Airtel)":     "Data Subscription (Airtel)",
            "🛺 Konga Order":                    "Konga Order",
            "📦 Jumia Purchase":                 "Jumia Purchase",
            "📱 Airtime Top-up (MTN)":           "Airtime Top-up (MTN)"
          }
        },
        {
          "name": "payment_channel",
          "type": "select",
          "label": "Payment Channel"
        },
        {
          "name": "location",
          "type": "select",
          "label": "Location (City)"
        },
        {
          "name": "device_used",
          "type": "select",
          "label": "Device Used"
        }
      ]
    },
    {
      "title": "👤 Sender Profile",
      "fields": [
        { "name": "sender_persona", "type": "select", "label": "Sender Persona" },
        {
          "name": "bvn_linked",
          "type": "toggle",
          "label": "BVN Linked?",
          "true_label":  "Yes — Account is BVN verified (lower risk)",
          "false_label": "No — No BVN registered (higher risk)"
        },
        {
          "name": "new_device_transaction",
          "type": "toggle",
          "label": "New Device?",
          "true_label":  "Yes — First time on this device (higher risk)",
          "false_label": "No — Recognized device (lower risk)"
        }
      ]
    },
    {
      "title": "⚠️ Risk Signals",
      "fields": [
        {
          "name": "time_since_last_transaction",
          "type": "pills",
          "label": "⏱ Time Since Last Transaction — how recently was the previous transaction made?",
          "short_label": "Minutes Since Last Transaction",
          "options": {
            "Just now (< 1 min)": 0.5,
            "< 30 minutes": 15.0,
            "1 hour": 60.0,
            "3 hours": 180.0,
            "Half day": 720.0,
            "1 day+": 1440.0
          },
          "default": "Just now (< 1 min)"
        },
        {
          "name": "spending_deviation_score",
          "type": "pills",
          "label": "📈 Spending Deviation — how far this amount differs from the sender's usual pattern",
          "short_label": "Spending Deviation Score",
          "options": {
            "Normal (0)": 0.0,
            "Moderate (2)": 2.0,
            "Unusual (5)": 5.0,
            "Very unusual (8)": 8.0,
            "Extreme (10)": 10.0
          },
          "default": "Normal (0)"
        },
        {
          "name": "velocity_score",
          "type": "pills",
          "label": "🔁 Velocity Score — number of rapid back-to-back transactions in a short window",
          "short_label": "Velocity Score",
          "options": {
            "None (0)": 0,
            "Low (1-3)": 2,
            "Medium (4-9)": 6,
            "High (10-15)": 12,
            "Very high (16+)": 18
          },
          "default": "None (0)"
        },
        {
          "name": "geo_anomaly_score",
          "type": "pills",
          "label": "📍 Geo Anomaly — how unusual the transaction location is compared to typical activity",
          "short_label": "Geo Anomaly Score",
          "options": {
            "Normal (0.0)": 0.0,
            "Moderate anomaly (0.3)": 0.3,
            "Unusual (0.7)": 0.7,
            "Impossible travel (1.0)": 1.0
          },
          "default": "Normal (0.0)"
        }
      ]
    }
  ]
}